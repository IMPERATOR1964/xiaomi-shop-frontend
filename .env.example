# Базовый URL API. В dev оставляем /api — Vite-proxy сам перешлёт
# на бэк (см. vite.config.js). В prod nginx делает то же самое.
VITE_API_URL=/api

# Опционально: куда vite-proxy шлёт /api в dev-режиме.
# По умолчанию http://localhost:8080. Если бэк на сервере —
# поставь, например, http://176.12.70.208:8080
# VITE_API_PROXY_TARGET=http://localhost:8080
